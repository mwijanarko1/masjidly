    "onboarding.explore_timetable.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مرّر صف الأيام أفقياً لاختيار يوم آخر. استخدم سهمي الشهر للانتقال بين الأشهر. مرّر قائمة الصلوات لذلك اليوم. عند الانتهاء، اضغط متابعة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe the date row sideways to pick another day. Use the month arrows to load other months. Scroll the prayer list for the selected day. When you’re done exploring, tap Continue."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تاریخوں کی قطار کو سائیڈ سے سلائیڈ کر کے دوسرا دن چنیں۔ مہینے بدلنے کے لیے تیر والے بٹن استعمال کریں۔ منتخب دن کی نمازوں کی فہرست سکرول کریں۔ دیکھ لیں تو جاری رکھیں پر ٹیپ کریں۔"
