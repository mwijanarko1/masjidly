    "onboarding.explore_settings.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المسجد يحدد مصدر الأوقات. تنسيق 24 ساعة يغيّر شكل الساعات. الإشعارات: التفعيل الرئيسي ثم قناة الأذان والإقامة، مع تذكيرات اختيارية قبل كل منهما. مرّر لأسفل لرؤية كل الخيارات، ثم اضغط متابعة."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mosque picks which masjid’s times you see. 24-hour time changes how clocks read. Notifications has a master switch; when on, you can enable adhan and iqamah alerts separately and set optional reminders before each. Scroll to skim everything, then tap Continue."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مسجد سے اوقات کا ذریعہ طے ہوتا ہے۔ 24 گھنٹے والا وقت گھڑیوں کا انداز بدلتا ہے۔ نوٹیفیکیشنز میں ماسٹر سوئچ ہے؛ چالو ہونے پر اذان اور اقامت الگ سے چالو کر سکتے ہیں اور ہر سے پہلے یاد دہانی۔ نیچے سکرول کر کے دیکھ لیں، پھر جاری رکھیں پر ٹیپ کریں۔"
          }
        }
      }
    },
    "onboarding.explore_settings.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ماذا تفعل هذه الإعدادات؟"
