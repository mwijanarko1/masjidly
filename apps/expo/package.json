{
  "name": "masjidly",
  "version": "1.1.0",
  "description": "Masjidly - Official Masjid Prayer Times",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "start:tunnel": "expo start --tunnel",
    "android:usb": "adb reverse tcp:8081 tcp:8081 && expo start --localhost --android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:eas": "eas build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern .expo --ignore-pattern android --ext .js,.jsx,.ts,.tsx"
  },
  "keywords": [
    "expo",
    "react-native",
    "template",
    "typescript",
    "navigation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mwijanarko1/Expo-RN-Template"
  },
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "dependencies": {
    "@expo-google-fonts/comfortaa": "^0.4.1",
    "@expo/metro-runtime": "~55.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.94.4",
    "convex": "^1.37.0",
    "eslint-config-expo": "~55.0.1",
    "expo": "~55.0.26",
    "expo-audio": "~55.0.14",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.18",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.3"
