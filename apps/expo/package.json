{
  "name": "expo-rn-template",
  "version": "1.0.0",
  "description": "A reusable React Native template using Expo with TypeScript, navigation, and best practices",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:eas": "eas build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint ."
  },
  "keywords": [
    "expo",
    "react-native",
    "template",
    "typescript",
    "navigation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mwijanarko1/Expo-RN-Template"
  },
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@tanstack/react-query": "^5.94.4",
    "eslint-config-expo": "~55.0.0",
    "expo": "^55.0.8",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.9",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.84.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.21.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "react-test-renderer": "19.2.4",
    "jest-expo": "~55.0.11",
    "typescript": "~5.9.3"
  },
  "private": false
